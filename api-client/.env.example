# OpenWebUI Configuration
# Copy this file to .env and fill in your actual values

# Your OpenWebUI server URL (e.g., http://192.168.0.xxx:3000)
OPENWEBUI_URL=http://your-server-ip:3000

# Your API key (from OpenWebUI Settings → Account → API Keys)
OPENWEBUI_API_KEY=sk-your-api-key-here

# Your SAT Knowledge Base ID (from Workspace → Knowledge)
KNOWLEDGE_BASE_ID=your-knowledge-base-id-here

# Model to use (default: gpt-oss:20b-cloud)
MODEL=gpt-oss:20b-cloud
